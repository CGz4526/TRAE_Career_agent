# 后端职途 Java 业务服务环境变量
# 用法：复制为 deploy/env/java.env（去掉 .example）后，systemd 会自动读取
# 注意：MySQL/Redis 由 docker-compose 映射到主机 3308 / 6380，故连 127.0.0.1:3308 / 6380
PORT=8080

MYSQLHOST=127.0.0.1
MYSQLPORT=3308
MYSQLDATABASE=career_agent
MYSQLUSER=career
MYSQLPASSWORD=career123456

REDISHOST=127.0.0.1
REDISPORT=6380
REDISPASSWORD=redis123456

AI_SERVICE_URL=http://127.0.0.1:8001
