# 后端职途 Python AI 服务环境变量
# 用法：复制为 deploy/env/python.env（去掉 .example）后，systemd 会自动读取
LLM_API_KEY=your-volcark-key-here
LLM_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
LLM_MODEL=doubao-pro-32k
LLM_VISION_MODEL=

PORT=8001
DEBUG=false
ALLOWED_ORIGINS=http://career.your.domain
JAVA_BACKEND_URL=http://127.0.0.1:8080
